# Copy to .env.local for local overrides (never commit .env.local).

# Backend API base URL — no trailing slash.
# Used by next.config.ts to configure the server-side /api/* proxy rewrite.
# Defaults to http://127.0.0.1:8000 when unset (local dev).
# On Vercel: set to your Render backend URL, e.g. https://promptsentinel-api.onrender.com
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Set to "1" to show the amber Demo Mode banner in the global layout.
# Must be set at build time (Next.js bakes NEXT_PUBLIC_* vars in during build).
# On Vercel: add as an Environment Variable, then redeploy.
NEXT_PUBLIC_DEMO_MODE=
