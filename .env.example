# PromptSentinel — environment variables
# Copy this file to .env and adjust values before starting the server.
# The server reads these from the shell environment (not from a .env file directly);
# set them in your shell or pass them via run.ps1 flags.

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------

# Master API key for admin-only endpoints (GET /admin/users, rotate-key, etc.).
# If unset the server runs in open/dev mode — any request is accepted.
# In production always set a strong random value.
#
#   python -c "import secrets; print(secrets.token_hex(32))"
#
PROMPTSENTINEL_API_KEY=

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------

# Maximum requests per minute per IP address.
# Set to 0 (default) to disable rate limiting entirely.
PROMPTSENTINEL_RATE_LIMIT_PER_MIN=0

# Redis connection URL — optional.
# When set, rate limiting uses Redis counters (cross-worker safe).
# When unset, the DB-backed fallback is used automatically.
# REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# CORS (production)
# ---------------------------------------------------------------------------

# Comma-separated list of allowed origins for CORS.
# If unset, only localhost dev origins are allowed (ports 3000 and 8000).
# Example: https://app.example.com,https://api.example.com
PROMPTSENTINEL_CORS_ORIGINS=

# ---------------------------------------------------------------------------
# Database path
# ---------------------------------------------------------------------------

# Absolute or relative path to the SQLite database file.
# Set to a persistent-disk path in cloud deployments (e.g. /data/promptsentinel.db).
# Default: ./promptsentinel.db (relative to the working directory)
PROMPTSENTINEL_DB_PATH=

# ---------------------------------------------------------------------------
# Development helpers
# ---------------------------------------------------------------------------

# Set to "1" to drop and recreate the SQLite database on startup.
# WARNING: destroys all data. Only for local dev / CI.
PROMPTSENTINEL_DEV_RESET_DB=

# ---------------------------------------------------------------------------
# Application URLs  (required in production for billing redirects + email links)
# ---------------------------------------------------------------------------

# Public base URL of the backend (no trailing slash).  Used in billing redirects.
# Example: https://api.example.com
PROMPTSENTINEL_APP_URL=

# Same URL used in magic-link emails (may differ from APP_URL if frontend handles links).
PROMPTSENTINEL_PUBLIC_BASE_URL=

# ---------------------------------------------------------------------------
# SMTP / passwordless (magic-link) auth
# ---------------------------------------------------------------------------

# Required only when magic-link login is enabled (PROMPTSENTINEL_DEV_LOGIN=1).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Set to "1" to enable the magic-link login flow (requires SMTP settings above).
PROMPTSENTINEL_DEV_LOGIN=

# ---------------------------------------------------------------------------
# Stripe billing
# ---------------------------------------------------------------------------

# Stripe secret key (sk_live_... or sk_test_...).
STRIPE_SECRET_KEY=

# ID of the recurring price for the Pro plan (price_...).
STRIPE_PRICE_ID_PRO=

# URLs Stripe redirects to after checkout.
STRIPE_SUCCESS_URL=https://app.example.com/billing/success
STRIPE_CANCEL_URL=https://app.example.com/billing/cancel

# Webhook signing secret (whsec_...) — Stripe Dashboard → Webhooks → your endpoint.
# For local testing use the secret printed by `stripe listen`.
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Uvicorn / application log level.
# Accepted values: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Demo / tunnel deployment (recommended values)
# ---------------------------------------------------------------------------
# For a local demo shared via Cloudflare Tunnel or similar:
#
#   PROMPTSENTINEL_API_KEY=<random 32-byte hex>  — required for admin seed button
#   PROMPTSENTINEL_RATE_LIMIT_PER_MIN=60         — prevents abuse on public link
#   PROMPTSENTINEL_CORS_ORIGINS=                 — leave empty; Next.js proxies API
#
# The frontend (port 3000) proxies /api/* to the local backend, so only
# the frontend port needs to be tunnelled. No LLM API keys are needed —
# all detection is rule-based and runs entirely offline.
